# ============================================
# Supabase Configuration
# Ambil dari: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — JANGAN expose ke frontend (hanya di API Routes & Edge Functions)
# Ambil dari: Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Payment Provider Selector
# ============================================
# MIDTRANS | DOKU | MANUAL
PAYMENT_PROVIDER_ACTIVE=MIDTRANS

# Optional feature toggle (frontend display control)
NEXT_PUBLIC_ENABLE_DYNAMIC_QRIS=false

# ============================================
# Midtrans Payment Gateway (Dynamic QRIS)
# Daftar di: https://dashboard.midtrans.com
# Ambil dari: Settings > Access Keys / API Keys
# ============================================

# Server Key Midtrans
MIDTRANS_SERVER_KEY=Mid-server-your-secret-key-here

# Production flag
# false = sandbox, true / unset = production
MIDTRANS_IS_PRODUCTION=false

# Optional: URL webhook Midtrans di dashboard
# https://<domain-anda>/api/midtrans/notification

# ============================================
# DOKU Payment Gateway (Checkout / API)
# Daftar di: https://dashboard.doku.com
# Gunakan hanya di server-side (kecuali public key yang memang public)
# ============================================

# Wajib untuk auth/token flow DOKU
DOKU_CLIENT_ID=your-doku-client-id
DOKU_SECRET_KEY=your-doku-secret-key

# API key dari dashboard DOKU
DOKU_API_KEY=your-doku-api-key

# Opsional: key public untuk browser-side encryption/use case tertentu
DOKU_PUBLIC_KEY=your-doku-public-key
NEXT_PUBLIC_DOKU_MERCHANT_PUBLIC_KEY=your-doku-merchant-public-key

# Endpoint token DOKU (sesuaikan sandbox/production)
# Sandbox example: https://api-sandbox.doku.com/oauth/token
# Production example: https://api.doku.com/oauth/token
DOKU_TOKEN_URL=https://api-sandbox.doku.com/oauth/token

# Callback dan webhook endpoint aplikasi kamu
# Callback untuk redirect hasil pembayaran
DOKU_CALLBACK_URL=https://smartvalley.katalara.com/kantin/payment/result
# Webhook untuk notifikasi status pembayaran
DOKU_WEBHOOK_URL=https://smartvalley.katalara.com/api/doku/notification

# Secret token webhook tambahan dari dashboard DOKU jika digunakan.
# Verifikasi signature HMAC tetap memakai DOKU_CLIENT_ID + DOKU_SECRET_KEY.
DOKU_WEBHOOK_SECRET=your-doku-webhook-secret

# Mode sandbox/production DOKU: 'true' = sandbox (default), 'false' = production
DOKU_IS_SANDBOX=true

# ============================================
# Cara setup:
# 1. Copy file ini ke .env.local
# 2. Isi semua nilai dengan kredensial yang benar
# 3. JANGAN commit .env.local ke git (sudah ada di .gitignore)
# 4. Untuk Vercel: tambahkan semua variabel ini di
#    Settings > Environment Variables
# ============================================
