# ============================================
# Supabase Configuration
# Ambil dari: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — JANGAN expose ke frontend (hanya di API Routes & Edge Functions)
# Ambil dari: Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Xendit Payment Gateway (Dynamic QRIS)
# Daftar di: https://dashboard.xendit.co
# Ambil dari: Settings > API Keys
# ============================================

# Secret Key Xendit
# Development: diawali dengan xnd_development_
# Production:  diawali dengan xnd_production_
XENDIT_SECRET_KEY=xnd_development_your-secret-key-here

# Webhook Token — dipakai untuk verifikasi webhook dari Xendit
# Ambil dari: Settings > Webhooks > Webhook Token
XENDIT_WEBHOOK_TOKEN=your-webhook-token-here

# ============================================
# Cara setup:
# 1. Copy file ini ke .env.local
# 2. Isi semua nilai dengan kredensial yang benar
# 3. JANGAN commit .env.local ke git (sudah ada di .gitignore)
# 4. Untuk Vercel: tambahkan semua variabel ini di
#    Settings > Environment Variables
# ============================================
